@model RestaurantReviewCreateViewModel
@{
    ViewData["Title"] = "Puan ve Yorum";
    var isUpdate = ViewBag.IsUpdate == true;
}

<h2>@(isUpdate ? "Yorumu Guncelle" : "Puan ve Yorum Yaz")</h2>
<p class="text-muted">Restoran: <strong>@Model.RestaurantName</strong></p>

<form asp-action="Create" method="post" class="row g-3 feature-card p-3">
    <input type="hidden" asp-for="RestaurantId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-4">
        <label asp-for="Rating" class="form-label"></label>
        <select asp-for="Rating" class="form-select">
            @for (var i = 5; i >= 1; i--)
            {
                <option value="@i">@i yildiz</option>
            }
        </select>
        <span asp-validation-for="Rating" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Comment" class="form-label"></label>
        <textarea asp-for="Comment" class="form-control" rows="4" maxlength="1000" placeholder="Deneyiminizi yazin (en az 10 karakter)"></textarea>
        <span asp-validation-for="Comment" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-order">Kaydet</button>
        <a class="btn btn-outline-secondary" asp-controller="Menu" asp-action="Index" asp-route-restaurantId="@Model.RestaurantId">Vazgec</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
