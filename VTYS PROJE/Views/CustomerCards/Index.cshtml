@model List<VTYS_PROJE.Models.customer_card>

@{
    ViewData["Title"] = "Kart Bilgilerim";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Kart Bilgilerim</h2>

        <a asp-action="Create" class="btn btn-primary">
            Yeni Kart Ekle
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Henüz kayıtlı kart bilginiz bulunmuyor.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Kart Sahibi</th>
                        <th>Kart Numarası</th>
                        <th>Son Kullanma</th>
                        <th>Kayıt Tarihi</th>
                        <th width="180">İşlemler</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.card_holder_name
                            </td>

                            <td>
                                **** **** ****
                                @item.card_number.Substring(
                                         Math.Max(0, item.card_number.Length - 4))
                            </td>

                            <td>
                                @item.expiry_month/@item.expiry_year
                            </td>

                            <td>
                                @item.created_at.ToString("dd.MM.yyyy")
                            </td>

                            <td>

                                <a asp-action="Edit"
                                       asp-route-id="@item.card_id"
                                       class="btn btn-warning btn-sm">
                                    Düzenle
                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@item.card_id"
                                      method="post"
                                      style="display:inline;">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-danger btn-sm"
                                            onclick="return confirm('Kart silinsin mi?')">
                                        Sil
                                    </button>

                                </form>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        </div>
    }

</div>