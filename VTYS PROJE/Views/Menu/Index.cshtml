@model List<VTYS_PROJE.Models.product>

@{
    ViewData["Title"] = "Menü";
    var restaurantId = ViewBag.RestaurantId;
}

<div class="container mt-4">

    <h2>@ViewBag.RestaurantName Menü</h2>

    <div class="mb-3">
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Tüm Restoranlar</a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">Bu restoranda henüz ürün yok.</div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Ürün</th>
                    <th>Kategori</th>
                    <th>Fiyat</th>
                    <th>Stok</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.product_name</td>
                        <td>@(item.category?.category_name ?? "Kategori yok")</td>
                        <td>@item.unit_price.ToString("0.00") TL</td>
                        <td>@item.stock_qty</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (restaurantId != null)
    {
        <a class="btn btn-primary"
               asp-controller="Orders"
               asp-action="Create">
            Sipariş Ver
        </a>
    }

    <partial name="_RestaurantReviews" />
    <partial name="_MenuYonetimRehberi" />

</div>