@model AskidaYemekDonateViewModel
@{
    ViewData["Title"] = "Askida Yemek Bagis";
}

@if (TempData["Success"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<h2>Askida Yemek Bagis</h2>
<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="alert alert-info mb-0">
            <div class="small">Mevcut Havuz</div>
            <strong>@ViewBag.PoolBalance TL</strong>
        </div>
    </div>
    <div class="col-md-8 d-flex align-items-center">
        <a class="btn btn-outline-secondary" asp-action="History">Askida Gecmis ve Rapor</a>
    </div>
</div>

<form asp-action="Donate" method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-4">
        <label asp-for="CustomerId" class="form-label"></label>
        <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select">
            <option value="">Musteri seciniz</option>
        </select>
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DonationType" class="form-label"></label>
        <select asp-for="DonationType" class="form-select">
            <option value="BALANCE">BALANCE</option>
            <option value="MEAL">MEAL</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Note" class="form-label"></label>
        <input asp-for="Note" class="form-control" />
        <span asp-validation-for="Note" class="text-danger"></span>
    </div>
    <div class="col-12 form-check">
        <input asp-for="IsAnonymous" class="form-check-input" />
        <label asp-for="IsAnonymous" class="form-check-label"></label>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-success">Bagis Yap</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
