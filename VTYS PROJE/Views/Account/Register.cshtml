@model RegisterCustomerViewModel
@{
    ViewData["Title"] = "Kayit Ol";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="feature-card">
            <h3 class="mb-1">Musteri Kayit</h3>
            <p class="text-muted small mb-3">LezzetJet hesabi olusturun</p>
            <form asp-action="Register" method="post" class="row g-3">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="col-12">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" data-input="letters" maxlength="120"
                           pattern="@InputValidation.LettersOnlyPattern" title="@InputValidation.LettersOnlyMessage" autocomplete="name" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control"
                           pattern="@InputValidation.EmailPattern" title="@InputValidation.EmailMessage" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" data-input="phone" maxlength="11" inputmode="numeric"
                           pattern="@InputValidation.PhonePattern" title="@InputValidation.PhoneMessage" placeholder="05xxxxxxxxx" autocomplete="tel" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger small d-block"></span>
                    <span class="text-muted small">En az 8 karakter, harf ve rakam</span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-order w-100">Kayit Ol</button>
                </div>
                <div class="col-12 text-center small">
                    Zaten hesabiniz var mi? <a asp-action="Login">Giris yapin</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
