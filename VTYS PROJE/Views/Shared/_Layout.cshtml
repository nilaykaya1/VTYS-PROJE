@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using VTYS_PROJE.Infrastructure
@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var authRole = session?.GetString(AuthSessionKeys.Role);
    var isCustomer = authRole == AuthSessionKeys.RoleCustomer;
    var isYonetici = authRole == AuthSessionKeys.RoleAdmin;

    var activeCustomerIdRaw = session?.GetString(AuthSessionKeys.CustomerId);
    var activeCustomerName = session?.GetString(AuthSessionKeys.CustomerName);
    var activeYoneticiName = session?.GetString(AuthSessionKeys.AdminName);
    var activeYoneticiIdRaw = session?.GetString(AuthSessionKeys.AdminId);

    string? userBadge = null;
    if (isCustomer && !string.IsNullOrWhiteSpace(activeCustomerIdRaw))
    {
        userBadge = !string.IsNullOrWhiteSpace(activeCustomerName)
            ? $"Musteri: {activeCustomerName}"
            : $"Musteri #{activeCustomerIdRaw}";
    }
    else if (isYonetici && !string.IsNullOrWhiteSpace(activeYoneticiIdRaw))
    {
        userBadge = !string.IsNullOrWhiteSpace(activeYoneticiName)
            ? $"Yonetici: {activeYoneticiName}"
            : $"Yonetici #{activeYoneticiIdRaw}";
    }
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LezzetJet</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg app-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-badge">LJ</span> LezzetJet
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#main-nav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="main-nav">
                    <ul class="navbar-nav me-auto gap-lg-1">
                        <li class="nav-item"><a class="nav-link" asp-controller="Restaurants" asp-action="Index">Restoranlar</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Menu" asp-action="Index">Menuler</a></li>
                        @if (isCustomer)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Orders" asp-action="Create">Siparis Ver</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Orders" asp-action="History">Siparislerim</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="AskidaYemek" asp-action="Donate">Askida Yemek</a></li>
                        }
                        @if (isYonetici)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Customers" asp-action="Index">Musteriler</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index">Yemekler / Urunler</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Restaurants" asp-action="Create">Restoran Ekle</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Orders" asp-action="History">Siparisler</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="AskidaYemek" asp-action="History">Askida Gecmis</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Reviews" asp-action="Index">Puan ve Yorumlar</a></li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                        @if (!string.IsNullOrWhiteSpace(userBadge))
                        {
                            <span class="badge rounded-pill text-bg-light border">@userBadge</span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Cikis</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="Account" asp-action="Login">Musteri Girisi</a>
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Account" asp-action="Register">Kayit Ol</a>
                            <a class="btn btn-sm btn-outline-dark" asp-controller="Account" asp-action="AdminLogin">Yonetici</a>
                        }
                        @if (isCustomer)
                        {
                            <a class="btn btn-order" asp-controller="Orders" asp-action="Create">Hemen Siparis</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container py-4">
        @if (TempData["Success"] is string successMessage)
        {
            <div class="alert alert-success">@successMessage</div>
        }
        @if (TempData["Error"] is string errorMessage)
        {
            <div class="alert alert-danger">@errorMessage</div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="app-footer border-top">
        <div class="container d-flex justify-content-between py-3 small text-muted">
            <span>LezzetJet - Online Yemek Siparis Sistemi</span>
            <span>Hizli, guvenli, modern siparis deneyimi</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
